# Example environment variables
# Use the *direct* database host from Supabase (no pooler) and include
# sslmode=require.  Replace [YOUR-PASSWORD] with the password from your
# Supabase project settings.
DATABASE_URL=postgresql://postgres:[Econeek11713]@db.vggerrylhlsebprfronu.supabase.co:5432/postgres?sslmode=require

# NOTE: pointing at the pooler URL (aws-1-us-east-2.pooler.supabase.com)
# will raise errors like "server didn't return client encoding" unless you
# also specify client_encoding=UTF8.  If you must use the pooler, add those
# query params and use the correct port (5432 or 6543 depending on setup):
#   postgresql://postgres:[YOUR-PASSWORD]@aws-1-us-east-2.pooler.supabase.com:5432/postgres?sslmode=require&client_encoding=UTF8
#   postgresql://postgres:[YOUR-PASSWORD]@aws-1-us-east-2.pooler.supabase.com:6543/postgres?sslmode=require&client_encoding=UTF8

SECRET_KEY=replace-me-with-a-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
